{
  "name": "cancer-qa-chatbot",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "node start-with-backend.js",
    "start-mobile-only": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:android": "eas build --platform android",
    "eas:build:android:preview": "eas build --platform android --profile preview",
    "test": "jest --verbose"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "axios": "^1.6.5",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.0",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.0",
    "expo-document-picker": "~13.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "react-test-renderer": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "private": true,
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-native-async-storage|expo|@expo|react-native-safe-area-context)/)"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx",
      "json"
    ],
    "testPathIgnorePatterns": [
      "node_modules",
      "android",
      "builds"
    ]
  }
}
